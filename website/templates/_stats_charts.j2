{# Reusable, CSS-only statistics chart macros (no charting dependency).

   Shared by the dashboard's per-user panel (dashboard_panels.j2) and the
   app-wide /stats page (stats.j2). Every chart is keyboard-neutral and exposes
   a text fallback (ranked lists / titled bars) plus role="img" + aria-label for
   WCAG 2.2 AA. The Sessions/Annonces toggle is wired client-side by switching
   the `data-statpane` panes (dashboard.js / stats.js).

   Calendar colours: blue = campagne/MJ, green = one shot/joueur·euse. #}

{% set C_BLUE = 'oklch(61.302% 0.202 261.294)' %}
{% set C_GREEN = 'oklch(64.8% 0.15 160)' %}
{# Restriction palette: green (tout public) → yellow (16+) → red (18+). #}
{% set C_YELLOW = 'oklch(79.5% 0.162 86)' %}
{% set C_RED = 'oklch(63.7% 0.208 25.331)' %}

{% macro rythme(mode, hidden, months, values) %}
{% set maxv = (values | max) or 1 %}
<div data-statpane="{{ mode }}" class="{{ 'hidden' if hidden }}" role="img"
  aria-label="Activité des 12 derniers mois ({{ mode }})">
  <div class="flex items-end gap-1 h-16">
    {% for v in values %}
    <div class="flex-1 flex flex-col items-center justify-end h-full" title="{{ months[loop.index0] }} : {{ v }}">
      <span class="text-[0.55rem] font-mono text-base-content/60 leading-none mb-0.5">{{ v }}</span>
      <div class="w-full bg-primary/70 rounded-t" style="height: {{ (v / maxv * 100) | round }}%"></div>
    </div>
    {% endfor %}
  </div>
  <div class="flex gap-1 mt-1">
    {% for m in months %}<div class="flex-1 text-center text-[0.5rem] leading-none tracking-tighter text-base-content/50">{{ m }}</div>{% endfor %}
  </div>
</div>
{% endmacro %}

{% macro donut(title, a_label, b_label, sessions_pct, parties_pct, a_color, b_color) %}
<figure class="flex flex-col items-center gap-1" data-donut data-sessions="{{ sessions_pct }}"
  data-parties="{{ parties_pct }}" data-a="{{ a_label }}" data-b="{{ b_label }}" data-acolor="{{ a_color }}"
  data-bcolor="{{ b_color }}">
  <div class="relative size-16">
    <div data-ring class="size-16 rounded-full"></div>
    <div class="absolute inset-0 m-auto size-8 rounded-full bg-base-100"></div>
  </div>
  <figcaption class="text-xs font-semibold text-center">{{ title }}</figcaption>
  <div class="flex flex-wrap justify-center gap-x-2 gap-y-0.5 text-[0.7rem]">
    <span><span class="inline-block size-2 rounded-full align-middle" style="background: {{ a_color }}"></span>
      {{ a_label }} <span data-apct class="font-mono"></span></span>
    <span><span class="inline-block size-2 rounded-full align-middle" style="background: {{ b_color }}"></span>
      {{ b_label }} <span data-bpct class="font-mono"></span></span>
  </div>
</figure>
{% endmacro %}

{% macro _ranked(rows, mode, hidden) %}
<ol data-statpane="{{ mode }}" class="space-y-1 max-w-xs mx-auto {{ 'hidden' if hidden }}">
  {% for r in rows %}
  <li class="flex items-start gap-2 text-xs">
    <span class="w-3 shrink-0 text-center font-black text-base-content/40">{{ loop.index }}</span>
    <span class="flex-1 leading-tight break-words" title="{{ r.name }}">{{ r.name }}</span>
    <span class="shrink-0 font-mono text-[0.7rem] text-base-content/60">{{ r.n }}</span>
  </li>
  {% else %}
  <li class="text-xs text-base-content/40 text-center italic">—</li>
  {% endfor %}
</ol>
{% endmacro %}

{% macro top_list(title, sessions_rows, parties_rows) %}
<div>
  <h3 class="text-sm font-bold mb-1 text-center">{{ title }}</h3>
  {{ _ranked(sessions_rows, "sessions", False) }}
  {{ _ranked(parties_rows, "parties", True) }}
</div>
{% endmacro %}

{# Standalone ranked list (single basis, no sessions/annonces toggle).
   Same visual layout as the dashboard's top lists. #}
{% macro ranked_list(title, rows) %}
<div>
  <h3 class="text-sm font-bold mb-1 text-center">{{ title }}</h3>
  <ol class="space-y-1 max-w-xs mx-auto">
    {% for r in rows %}
    <li class="flex items-start gap-2 text-xs">
      <span class="w-4 shrink-0 text-center font-black text-base-content/40">{{ loop.index }}</span>
      <span class="flex-1 leading-tight break-words" title="{{ r.name }}">{{ r.name }}</span>
      <span class="shrink-0 font-mono text-[0.7rem] text-base-content/60">{{ r.n }}</span>
    </li>
    {% else %}
    <li class="text-xs text-base-content/40 text-center italic">—</li>
    {% endfor %}
  </ol>
</div>
{% endmacro %}
