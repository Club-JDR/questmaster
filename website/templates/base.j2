<!doctype html>
<html lang="fr" data-theme="light">

<head>
  {% block head %}
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Ysabeau:ital,wght@0,1;0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;0,1000;1,1;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900;1,1000&display=swap"
    rel="stylesheet">
  <link rel="shortcut icon" href="/static/img/favicon.ico">
  <script>document.documentElement.dataset.theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')</script>
  <link rel="stylesheet" href="{{ asset('assets/css/main.css') }}">
  {% for url in asset_css('assets/js/main.js') %}
  <link rel="stylesheet" href="{{ url }}">
  {% endfor %}
  <script src="{{ asset('assets/js/main.js') }}"></script>
  <title>QuestMaster - {% block title %}Accueil{% endblock %}</title>
  {% endblock %}
</head>

<body class="min-h-screen bg-base-200 font-sans">
  <a href="#{% block main_id %}main-content{% endblock %}"
    class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] btn btn-primary btn-sm">
    Aller au contenu principal
  </a>
  <nav class="navbar navbar-bg shadow-lg sticky top-0 z-50">
    <div class="navbar-start">
      <a id="brand" href="/">
        <img src="/static/img/logo.png" alt="QuestMaster" class="h-[50px]">
      </a>
    </div>
    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 text-base font-semibold">
        <li>
          <details>
            <summary id="annoncesMenu">Annonces</summary>
            <ul class="bg-base-100 text-base-content rounded-box z-50 w-56 p-2 shadow-xl">
              {% if payload.active_events %}
              <li class="menu-title">Événements</li>
              {% for event in payload.active_events %}
              <li><a href="/annonces/evenement/{{ event.id }}/">{{ event.emoji }} {{ event.name }}</a></li>
              {% endfor %}
              <li></li>
              {% endif %}
              {% if payload['username'] %}
              <li><a id="dashboardLink" href="/">Tableau de bord</a></li>
              {% endif %}
              <li class="menu-title">Joueur·euses</li>
              <li><a id="openGames" href="/annonces/">Annonces ouvertes</a></li>
              <li><a id="myPlayerGames" href="/mes_parties/"
                  class="{% if not payload['username'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] %} aria-disabled="true" tabindex="-1"{% endif %}>Mes parties</a></li>
              <li></li>
              <li class="menu-title">MJs</li>
              <li><a id="myGmGames" href="/mes_annonces/"
                  class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Mes
                  annonces</a></li>
              <li><a id="postNewGame" href="/annonce/"
                  class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Poster
                  une annonce</a></li>
            </ul>
          </details>
        </li>
        <li>
          <details>
            <summary id="infoMenu">Informations</summary>
            <ul class="bg-base-100 text-base-content rounded-box z-50 w-48 p-2 shadow-xl">
              <li><a id="trophiesLink" href="/badges/"
                  class="{% if not payload['username'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] %} aria-disabled="true" tabindex="-1"{% endif %}>Badges</a></li>
              <li><a id="trophiesLeaderboardLink" href="/badges/classement/">Classement</a></li>
              <li><a id="calendarLink" href="/calendrier/">Calendrier</a></li>
              <li><a id="statsLink" href="/stats/">Statistiques</a></li>
              <li><a id="systemsLink" href="/systemes/">Systèmes</a></li>
              <li><a id="vttsLink" href="/vtts/">VTTs</a></li>
            </ul>
          </details>
        </li>
        <li>
          <details>
            <summary id="demoMenu">Aide</summary>
            <ul class="bg-base-100 text-base-content rounded-box z-50 w-52 p-2 shadow-xl">
              <li><a id="playerDemo" href="/demo/">Générale</a></li>
              <li><a id="dashboardDemo" href="/demo/tableau-de-bord/">Tableau de bord</a></li>
              <li><a href="/demo/inscription/">M'inscrire</a></li>
              <li class="menu-title">MJs</li>
              <li><a href="/demo/poster/"
                  class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Poster
                  une annonce</a></li>
              <li><a href="/demo/gerer/"
                  class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Gérer
                  une annonce</a></li>
            </ul>
          </details>
        </li>
        {% if payload['is_admin'] %}
        <li>
          <details>
            <summary id="adminMenu" class="font-bold text-error">Admin</summary>
            <ul class="bg-base-100 text-base-content rounded-box z-50 w-64 p-2 shadow-xl">
              <li><a href="{{ url_for('admin.index') }}">Tableau de bord</a></li>
              {% for section in admin_sections %}
              <li><a href="{{ url_for(section.endpoint) }}">{{ section.label }}</a></li>
              {% endfor %}
            </ul>
          </details>
        </li>
        {% endif %}
      </ul>
    </div>
    <div class="navbar-end gap-2">
      {# Theme toggle #}
      <label class="flex cursor-pointer items-center gap-1" aria-label="Basculer le thème clair/sombre">
        <i class="ph ph-sun text-lg" aria-hidden="true"></i>
        <input type="checkbox" value="dark" class="toggle toggle-sm theme-controller" data-toggle-theme="dark,light"
          data-key="theme" />
        <i class="ph ph-moon text-lg" aria-hidden="true"></i>
      </label>
      {# User menu #}
      {% if payload['username'] %}
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" aria-haspopup="menu" aria-label="Menu utilisateur"
          class="btn btn-ghost btn-circle avatar">
          <div class="w-8 rounded-full">
            <img alt="{{ payload['username'] }}" src="{{ payload['avatar'] }}" />
          </div>
        </div>
        <ul tabindex="0"
          class="dropdown-content menu bg-base-100 text-base-content rounded-box z-50 w-52 p-2 shadow-xl">
          <li class="menu-title">{{ payload['username'] }}</li>
          <li><a href="/logout/">Me déconnecter</a></li>
        </ul>
      </div>
      {% else %}
      <a id="loginButton" href="/login/" class="btn btn-sm">Me connecter</a>
      {% endif %}
      {# Mobile hamburger #}
      <div class="dropdown dropdown-end lg:hidden">
        <div tabindex="0" role="button" aria-haspopup="menu" aria-label="Menu de navigation" class="btn btn-ghost"><i
            class="ph ph-list text-xl" aria-hidden="true"></i></div>
        <ul tabindex="0"
          class="dropdown-content menu bg-base-100 text-base-content rounded-box z-50 w-56 p-2 shadow-xl">
          <li>
            <details>
              <summary>Annonces</summary>
              <ul>
                {% if payload.active_events %}
                {% for event in payload.active_events %}
                <li><a href="/annonces/evenement/{{ event.id }}/">{{ event.emoji }} {{ event.name }}</a></li>
                {% endfor %}
                {% endif %}
                {% if payload['username'] %}
                <li><a href="/">Tableau de bord</a></li>
                {% endif %}
                <li><a href="/annonces/">Annonces ouvertes</a></li>
                <li><a href="/mes_parties/"
                    class="{% if not payload['username'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] %} aria-disabled="true" tabindex="-1"{% endif %}>Mes parties</a>
                </li>
                <li><a href="/mes_annonces/"
                    class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Mes
                    annonces</a></li>
                <li><a href="/annonce/"
                    class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Poster
                    une annonce</a></li>
              </ul>
            </details>
          </li>
          <li>
            <details>
              <summary>Informations</summary>
              <ul>
                <li><a href="/badges/"
                    class="{% if not payload['username'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] %} aria-disabled="true" tabindex="-1"{% endif %}>Badges</a></li>
                <li><a href="/badges/classement/">Classement</a></li>
                <li><a href="/calendrier/">Calendrier</a></li>
                <li><a href="/stats/">Statistiques</a></li>
                <li><a href="/systemes/">Systèmes</a></li>
                <li><a href="/vtts/">VTTs</a></li>
              </ul>
            </details>
          </li>
          <li>
            <details>
              <summary>Aide</summary>
              <ul>
                <li><a href="/demo/">Générale</a></li>
                <li><a href="/demo/tableau-de-bord/">Tableau de bord</a></li>
                <li><a href="/demo/inscription/">M'inscrire</a></li>
                <li><a href="/demo/poster/"
                    class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Poster
                    une annonce</a></li>
                <li><a href="/demo/gerer/"
                    class="{% if not payload['username'] or not payload['is_gm'] %}pointer-events-none opacity-50{% endif %}"{% if not payload['username'] or not payload['is_gm'] %} aria-disabled="true" tabindex="-1"{% endif %}>Gérer
                    une annonce</a></li>
              </ul>
            </details>
          </li>
          {% if payload['is_admin'] %}
          <li>
            <details>
              <summary class="font-bold text-error-accent">Admin</summary>
              <ul>
                <li><a href="{{ url_for('admin.index') }}">Tableau de bord</a></li>
                {% for section in admin_sections %}
                <li><a href="{{ url_for(section.endpoint) }}">{{ section.label }}</a></li>
                {% endfor %}
              </ul>
            </details>
          </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
  <div class="container mx-auto px-4 pt-4 space-y-2">
    {% for category, message in messages %}
    <div role="alert"
      class="alert {% if category == 'danger' %}alert-error{% elif category == 'success' %}alert-success{% elif category == 'warning' %}alert-warning{% else %}alert-info{% endif %}">
      {% if category == 'danger' %}<i class="ph ph-x-circle text-lg" aria-hidden="true"></i>
      {% elif category == 'success' %}<i class="ph ph-check-circle text-lg" aria-hidden="true"></i>
      {% elif category == 'warning' %}<i class="ph ph-warning text-lg" aria-hidden="true"></i>
      {% else %}<i class="ph ph-info text-lg" aria-hidden="true"></i>{% endif %}
      <span>{{ message }}</span>
      <button type="button" class="btn btn-sm btn-ghost btn-circle" aria-label="Fermer"
        onclick="this.closest('.alert').remove()">
        <i class="ph ph-x text-lg" aria-hidden="true"></i>
      </button>
    </div>
    {% endfor %}
  </div>
  {% endif %}
  {% endwith %}
  <main id="{{ self.main_id() }}" tabindex="-1"
    class="{% block main_class %}container mx-auto p-4 min-h-screen{% endblock %}" {% block main_attrs %}{% endblock %}>
    {% block content %}{% endblock %}
    <footer class="text-center mt-10 py-4">
      <p class="text-base-content/70">
        <strong>QuestMaster {{ app_version }}</strong><br>
        <a class="link link-hover" href="https://github.com/club-jdr/questmaster" target="_blank"
          rel="noopener noreferrer" aria-label="QuestMaster sur GitHub (nouvel onglet)">
          <i class="ph ph-github-logo" aria-hidden="true"></i>
        </a>
      </p>
    </footer>
  </main>
  {% block scripts %}
  <script src="https://cdn.jsdelivr.net/npm/animejs@3.2.1/lib/anime.min.js"
    integrity="sha256-XL2inqUJaslATFnHdJOi9GfQ60on8Wx1C2H8DYiN1xY=" crossorigin="anonymous"></script>
  <script src="https://cdn.jsdelivr.net/npm/konami@1.6.3/konami.min.js"></script>
  <script src="/static/js/konami.js"></script>
  <script src="/static/js/api-client.js"></script>
  <script>
    window.pageContext = {
      path: "{{ request.path }}",
      isAuthenticated: {% if payload.get('username') %}true{% else %} false{% endif %},
    isGM: {% if payload.get('is_gm') %} true{% else %} false{% endif %}
    };
  </script>
  <script src="{{ asset('assets/js/intro-manager.js') }}"></script>
  <script>
    // WCAG 4.1.2: mirror open/closed state onto the DaisyUI focus-dropdowns
    // (user menu + mobile hamburger). The <details>/<summary> nav menus convey
    // this natively; these role="button" dropdowns open on :focus-within.
    document.querySelectorAll('.dropdown > [role="button"]').forEach(function (trigger) {
      var dd = trigger.parentElement;
      trigger.setAttribute('aria-expanded', 'false');
      dd.addEventListener('focusin', function () { trigger.setAttribute('aria-expanded', 'true'); });
      dd.addEventListener('focusout', function () { trigger.setAttribute('aria-expanded', 'false'); });
    });
  </script>
  {% endblock %}
</body>

</html>