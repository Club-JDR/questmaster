<!doctype html>
<html lang="fr">

<head>
  <meta charset="utf-8" />
  <title>Calendrier</title>
  <meta name="viewport" content="height=device-height, width=device-width, initial-scale=1" />
  {% for url in asset_css('assets/js/calendar.js') %}
  <link rel="stylesheet" href="{{ url }}">
  {% endfor %}
  <style>
    body,
    html {
      margin: 0;
      padding: 0;
      height: 100%;
      background: white;
    }

    #month-games-calendar {
      max-width: 100%;
      height: 100%;
    }

    .fc-event {
      white-space: normal !important;
      line-height: 1.2em;
      padding: 2px;
    }

    .fc-event-title {
      white-space: normal !important;
      overflow: visible !important;
      text-overflow: initial;
    }

    .fc-daygrid-event {
      font-size: 0.85em;
      padding: 2px 4px;
    }

    .fc-event.event-oneshot {
      color: oklch(64.8% 0.15 160) !important;
    }

    .fc-event.event-campaign {
      color: oklch(61.302% 0.202 261.294) !important;
    }
  </style>
</head>

<body>
  <div id="month-games-calendar"></div>
  <script src="/static/js/api-client.js"></script>
  <script src="{{ asset('assets/js/calendar.js') }}"></script>
</body>

</html>