<div class="col [perspective:1200px] [aspect-ratio:63/88] self-start shrink-0 w-[85vw] snap-start sm:w-auto">
  <div class="block h-full rounded-2xl border-4 border-base-300 shadow-md relative overflow-hidden bg-base-200">

    {# Full-bleed image placeholder #}
    <div class="skeleton absolute inset-0"></div>

    {# Top overlay: type icon + title + player count #}
    <div class="absolute inset-x-0 top-0 px-3 pt-3 pb-10 z-10
                flex items-start justify-between gap-2
                bg-gradient-to-b from-black/75 via-black/30 to-transparent">
      <div class="flex items-center gap-2 min-w-0">
        <div class="w-8 h-8 rounded-full bg-white/20 animate-pulse shrink-0"></div>
        <div class="min-w-0 space-y-1.5">
          <div class="h-3.5 w-24 rounded bg-white/30 animate-pulse"></div>
          <div class="h-2.5 w-14 rounded bg-white/20 animate-pulse"></div>
        </div>
      </div>
      <div class="shrink-0 flex flex-col items-center gap-1">
        <div class="h-6 w-8 rounded bg-white/30 animate-pulse"></div>
        <div class="h-2 w-14 rounded bg-white/20 animate-pulse"></div>
      </div>
    </div>

    {# Bottom: gradient cap + dark panel #}
    <div class="absolute inset-x-0 bottom-0 z-10">
      <div class="h-8 bg-gradient-to-t from-black/80 to-transparent pointer-events-none"></div>
      <div class="bg-black/75 backdrop-blur-sm px-3 py-2 space-y-1.5">

        {# GM row: avatar circle + name bar #}
        <div class="flex items-center gap-2 text-xs">
          <div class="w-14 shrink-0">
            <div class="w-6 h-6 rounded-full bg-white/20 animate-pulse"></div>
          </div>
          <div class="flex-1 h-2.5 rounded bg-white/20 animate-pulse"></div>
        </div>

        {# System + VTT row: two icon circles + name bar #}
        <div class="flex items-center gap-2 text-xs">
          <div class="w-14 shrink-0 flex gap-1">
            <div class="w-6 h-6 rounded-full bg-white/20 animate-pulse"></div>
            <div class="w-6 h-6 rounded-full bg-white/20 animate-pulse opacity-60"></div>
          </div>
          <div class="flex-1 h-2.5 rounded bg-white/20 animate-pulse"></div>
        </div>

        {# Date row: calendar + clock circles + date line + frequency line #}
        <div class="flex items-center gap-2 text-xs">
          <div class="w-14 shrink-0 flex gap-1">
            <div class="w-6 h-6 rounded-full bg-white/20 animate-pulse"></div>
            <div class="w-6 h-6 rounded-full bg-white/20 animate-pulse"></div>
          </div>
          <div class="flex-1 space-y-1">
            <div class="h-2.5 rounded bg-white/20 animate-pulse"></div>
            <div class="h-2 w-3/4 rounded bg-white/20 animate-pulse opacity-60"></div>
          </div>
        </div>

        {# Tags row: restriction badge + two tag pills #}
        <div class="flex flex-wrap gap-1 justify-center items-center pt-0.5">
          <div class="h-4 w-20 rounded-full bg-white/20 animate-pulse"></div>
          <div class="h-4 w-12 rounded-full bg-white/20 animate-pulse"></div>
          <div class="h-4 w-8 rounded-full bg-white/20 animate-pulse opacity-60"></div>
        </div>

      </div>
    </div>

  </div>
</div>
