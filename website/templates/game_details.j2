{% block scripts %}
{{ super() }}
<script src="https://cdn.jsdelivr.net/npm/add-to-calendar-button@2.6.16/dist/atcb.min.js"></script>
<script src="/static/js/game-events.js"></script>
<script src="/static/js/user-typeahead.js" defer></script>
<script>
  function openCalendar(btn) {
    atcb_action({
      name: btn.dataset.name,
      options: ['Apple', 'Google', 'iCal', 'Outlook.com', 'Yahoo'],
      startDate: btn.dataset.startDate,
      endDate: btn.dataset.endDate,
      startTime: btn.dataset.startTime,
      endTime: btn.dataset.endTime,
      timeZone: 'Europe/Paris',
      description: btn.dataset.description,
      language: 'fr',
      listStyle: 'dropdown'
    }, btn);
  }

  function openEditSessionModal(btn) {
    var modal = document.getElementById('editSessionModal');
    modal.querySelector('.session-modal-title').textContent = 'Éditer la session #' + btn.dataset.sessionIndex;
    modal.querySelector('.session-modal-date').textContent = btn.dataset.display;
    document.getElementById('editSessionForm').action =
      '/annonces/{{ game.slug }}/sessions/' + btn.dataset.sessionId + '/editer';
    modal.querySelector('[name="date_start"]').value = btn.dataset.start;
    modal.querySelector('[name="date_end"]').value = btn.dataset.end;
    modal.showModal();
  }

  function openDeleteSessionModal(btn) {
    var modal = document.getElementById('deleteSessionModal');
    modal.querySelector('.session-modal-title').textContent = 'Supprimer la session #' + btn.dataset.sessionIndex;
    modal.querySelector('.session-modal-date').textContent = btn.dataset.display;
    document.getElementById('deleteSessionForm').action =
      '/annonces/{{ game.slug }}/sessions/' + btn.dataset.sessionId + '/supprimer';
    modal.showModal();
  }

  function openAddSessionModal() {
    var modal = document.getElementById('addSessionModal');
    var btn = document.getElementById('addSessionButton');
    var sessionLength = parseInt(btn.dataset.sessionLength, 10);
    var frequency = btn.dataset.frequency || '';
    var pad = function (n) { return String(n).padStart(2, '0'); };
    var toLocalISO = function (d) {
      return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
    };

    // Find the latest existing session start from the DOM
    var lastStart = null;
    document.querySelectorAll('.session-row[data-session-start]').forEach(function (row) {
      var d = new Date(row.dataset.sessionStart);
      if (!lastStart || d > lastStart) lastStart = d;
    });

    var start;
    if (lastStart && frequency && frequency !== 'other') {
      start = new Date(lastStart.getTime());
      if (frequency === 'weekly') {
        start.setDate(start.getDate() + 7);
      } else if (frequency === 'bi-weekly') {
        start.setDate(start.getDate() + 14);
      } else if (frequency === 'monthly') {
        start.setMonth(start.getMonth() + 1);
      }
    } else {
      var gameDate = new Date(btn.dataset.gameDate);
      var now = new Date();
      if (gameDate > now) {
        start = gameDate;
      } else {
        // Game date is in the past: use today at the same time-of-day
        start = new Date(now.getFullYear(), now.getMonth(), now.getDate(),
          gameDate.getHours(), gameDate.getMinutes());
      }
    }

    var end = new Date(start.getTime() + sessionLength * 3600000);
    modal.querySelector('[name="date_start"]').value = toLocalISO(start);
    modal.querySelector('[name="date_end"]').value = toLocalISO(end);
    modal.showModal();
  }

  document.addEventListener('DOMContentLoaded', function () {
    var archiveModal = document.getElementById('confirmArchiveModal');
    if (archiveModal) {
      var countdownInterval = null;
      var originalShowModal = archiveModal.showModal.bind(archiveModal);
      archiveModal.showModal = function () {
        originalShowModal();
        var btn = document.getElementById('archiveBtn');
        if (!btn) return;
        var count = 10;
        btn.disabled = true;
        btn.textContent = 'Archiver (' + count + ')';
        countdownInterval = setInterval(function () {
          count--;
          if (count <= 0) {
            clearInterval(countdownInterval);
            btn.disabled = false;
            btn.textContent = 'Archiver';
          } else {
            btn.textContent = 'Archiver (' + count + ')';
          }
        }, 1000);
      };
      archiveModal.addEventListener('close', function () {
        clearInterval(countdownInterval);
        var btn = document.getElementById('archiveBtn');
        if (btn) { btn.disabled = true; btn.textContent = 'Archiver (10)'; }
      });
    }
  });

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.session-row[data-session-start]').forEach(function (row) {
      var start = new Date(row.dataset.sessionStart);
      var now = new Date();
      var badge = row.querySelector('.session-badge');
      if (!badge) return;
      var diffMs = start - now;
      var diffDays = Math.round(diffMs / 86400000);
      if (diffMs < 0) {
        badge.innerHTML = '<span class="badge badge-sm opacity-60">Passée</span>';
        row.classList.add('opacity-60');
      } else if (diffDays === 0) {
        badge.innerHTML = '<span class="badge badge-success badge-sm animate-pulse font-bold">Aujourd\'hui</span>';
      } else if (diffDays === 1) {
        badge.innerHTML = '<span class="badge badge-success badge-sm font-bold">Demain</span>';
      } else if (diffDays <= 7) {
        badge.innerHTML = '<span class="badge badge-info badge-sm">Dans ' + diffDays + 'j</span>';
      } else if (diffDays <= 30) {
        var weeks = Math.round(diffDays / 7);
        badge.innerHTML = '<span class="badge badge-sm">Dans ' + weeks + ' sem.</span>';
      }
    });
  });
</script>
{% endblock %}