{% extends "base.j2" %}

{% block title %}{{ game.name }}{% endblock %}

{% block head %}
{{ super() }}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/add-to-calendar-button@2.6.16/assets/css/atcb.min.css">
<style>
  .player-avatar-wrapper:hover .avatar {
    transform: scale(1.1);
    transition: transform 0.15s ease;
  }

  .session-row:hover {
    background-color: var(--color-base-200);
  }
</style>
{% endblock %}

{% block main_class %}container mx-auto px-4 pb-16 min-h-screen{% endblock %}
{% block main_id %}game-details-container{% endblock %}
{% block main_attrs %}data-game-id="{{ game.slug }}"{% endblock %}

{% block content %}

{# ── HERO ── #}
<section class="relative rounded-2xl overflow-hidden mt-4 mb-4 shadow-2xl">
  <img src="{{ game.img or '/static/img/placeholder.jpeg' }}" alt="{{ game.name }}"
    class="absolute inset-0 w-full h-full object-cover"
    onerror="this.onerror=null;this.src='/static/img/placeholder.jpeg'" />

  {# Top gradient — keeps pills readable without darkening the whole image #}
  <div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-black/60 to-transparent pointer-events-none"></div>

  {# Status indicator — top-right pill #}
  <div class="absolute top-3 right-3 sm:top-4 sm:right-4 z-10">
    {% if game.status == 'open' %}
    <div class="inline-flex items-center gap-2 color-oneshot rounded-full px-4 py-1.5 shadow border">
      <div class="inline-grid *:[grid-area:1/1]">
        <div class="w-2 h-2 rounded-full bg-current animate-ping opacity-75"></div>
        <div class="w-2 h-2 rounded-full bg-current"></div>
      </div>
      <span class="text-sm font-bold">Ouverte</span>
    </div>
    {% elif game.status == 'closed' %}
    <div
      class="inline-flex items-center gap-2 bg-neutral text-neutral-content border border-neutral rounded-full px-4 py-1.5 shadow">
      <div class="w-2 h-2 rounded-full bg-current"></div>
      <span class="text-sm font-bold">Complet</span>
    </div>
    {% elif game.status == 'draft' %}
    <div
      class="inline-flex items-center gap-2 bg-info text-info-content border border-info rounded-full px-4 py-1.5 shadow">
      <div class="w-2 h-2 rounded-full bg-current"></div>
      <span class="text-sm font-bold">Brouillon</span>
    </div>
    {% elif game.status == 'archived' %}
    <div
      class="inline-flex items-center gap-2 bg-error text-error-content border border-error rounded-full px-4 py-1.5 shadow">
      <div class="w-2 h-2 rounded-full bg-current"></div>
      <span class="text-sm font-bold">Archivée</span>
    </div>
    {% endif %}
  </div>
  {# Type indicator — top-left pill #}
  <div class="absolute top-3 left-3 sm:top-4 sm:left-4 z-10">
    {% if game.special_event %}
    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 shadow border"
      style="background-color: {{ hex_color(game.special_event.color) }}; border-color: {{ hex_color(game.special_event.color) }}; color: {{ text_color(hex_color(game.special_event.color)) }};">
      <span class="text-sm font-bold">{{ game.special_event.emoji or '' }} {{ game.special_event.name }}</span>
    </div>
    {% elif game.type == 'campaign' %}
    <div class="inline-flex items-center gap-2 color-campaign rounded-full px-4 py-1.5 shadow border">
      <i class="ph ph-books"></i>
      <span class="text-sm font-bold">Campagne</span>
    </div>
    {% else %}
    <div class="inline-flex items-center gap-2 color-oneshot rounded-full px-4 py-1.5 shadow border">
      <i class="ph ph-scroll"></i>
      <span class="text-sm font-bold">Oneshot</span>
    </div>
    {% endif %}
  </div>

  {# Content column: spacer → title → info bar #}
  <div class="relative flex flex-col">
    <div class="h-32 sm:h-44 md:h-52"></div>

    {# Title — white text over a gradient bridge #}
    <div class="bg-gradient-to-b from-transparent via-black/60 to-black/80 px-4 sm:px-6 pt-8 pb-3">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-black leading-tight text-white drop-shadow-lg">
        {% if game.special_event %}{{ game.special_event.emoji }} {{ game.name }} {{ game.special_event.emoji }}{%
        else %}{{ game.name }}{% endif %}
      </h1>
    </div>

    {# Info bar — GM · system · date, like the game card bottom panel #}
    <div class="bg-black/75 backdrop-blur-sm px-4 sm:px-6 py-3">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs">

        {# GM #}
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-full overflow-hidden ring-1 ring-white/30 shrink-0">
            <img src="{{ game.gm.avatar }}" alt="{{ game.gm.name }}" class="w-full h-full object-cover">
          </div>
          <span class="font-semibold text-white">{{ game.gm.name }}</span>
        </div>

        <div class="w-px h-4 bg-white/20 hidden sm:block"></div>

        {# System + VTT #}
        <div class="flex items-center gap-2">
          <div class="flex gap-1">
            <div class="w-6 h-6 rounded-full bg-white/20 overflow-hidden flex items-center justify-center shrink-0">
              {% if game.system.icon %}<img src="{{ game.system.icon }}" alt="" class="w-full h-full object-cover">
              {% else %}<i class="ph ph-dice-five text-white/50"></i>{% endif %}
            </div>
            {% if game.vtt %}
            <div class="w-6 h-6 rounded-full bg-white/20 overflow-hidden flex items-center justify-center shrink-0">
              {% if game.vtt.icon %}<img src="{{ game.vtt.icon }}" alt="" class="w-full h-full object-cover">
              {% else %}<i class="ph ph-monitor text-white/50"></i>{% endif %}
            </div>
            {% endif %}
          </div>
          <span class="font-semibold text-white">{{ game.system.name or 'Système inconnu' }}{% if game.vtt %} / {{
            game.vtt.name }}{% endif %}</span>
        </div>

        <div class="w-px h-4 bg-white/20 hidden sm:block"></div>

        {# Date + length #}
        <div class="flex items-center gap-2">
          <i class="ph ph-calendar-dots text-white/60 shrink-0"></i>
          <span class="font-semibold text-white">{{ game.date|format_datetime('%a %d/%m · %Hh%M') }} · {{ game.length
            }}×{{ game.session_length }}h</span>
          {% if game.frequency %}
          <span class="text-white/80 italic hidden sm:inline">
            {%- if game.frequency == 'weekly' %}· Hebdo.
            {%- elif game.frequency == 'bi-weekly' %}· Bimensuelle
            {%- elif game.frequency == 'monthly' %}· Mensuelle
            {%- else %}· Variable{% endif %}
          </span>
          {% endif %}
        </div>

      </div>
    </div>
  </div>
</section>

{# ── TWO-COLUMN LAYOUT ── #}
<div class="flex flex-col lg:flex-row gap-4">

  {# ── LEFT COLUMN ── #}
  <div class="flex-1 min-w-0 space-y-4">

    {# ── DESCRIPTION + COMPLEMENT + METADATA ── #}
    <div class="card bg-base-100 shadow-md overflow-hidden">
      <div class="card-body p-4">
        <p class="whitespace-pre-line leading-relaxed text-base-content/90">{{ (game.description or 'Aucune
          description.') | urlize }}</p>
        {% if game.complement %}
        <details class="mt-3" open>
          <summary class="text-sm font-semibold text-base-content/70 cursor-pointer hover:text-base-content/70">
            <i class="ph ph-info"></i> Informations complémentaires
          </summary>
          <p class="whitespace-pre-line text-sm text-base-content/70 mt-2 leading-relaxed">{{ game.complement | urlize
            }}</p>
        </details>
        {% endif %}
      </div>

      {# Metadata footer — restriction · ambiance · classification #}
      <div class="bg-base-200/60 border-t border-base-200 px-4 py-3 space-y-3 text-xs">

        {# Row 1: Restriction + Ambiance side by side #}
        <div class="grid grid-cols-2 gap-4">

          {# Restriction #}
          <div class="flex flex-col gap-1">
            <span class="text-[0.6rem] uppercase tracking-wider text-base-content/70">Restriction</span>
            <div class="flex flex-wrap items-center gap-1">
              {% if game.restriction == 'all' %}
              <span class="badge color-oneshot gap-1 font-semibold badge-md"><i class="ph ph-seal-check"></i> Tout
                public</span>
              {% elif game.restriction == '16+' %}
              <span class="badge color-16plus gap-1 font-semibold badge-md"><i class="ph ph-seal-warning"></i>
                16+</span>
              {% else %}
              <span class="badge color-18plus gap-1 font-semibold badge-md"><i class="ph ph-seal-warning"></i>
                18+</span>
              {% endif %}
              {% if game.restriction_tags %}
              {% for tag in game.restriction_tags.split(',') %}
              <span class="badge badge-sm">{{ tag.strip()|truncate(20) }}</span>
              {% endfor %}
              {% endif %}
            </div>
          </div>

          {# Ambiance #}
          {% if game.ambience %}
          <div class="flex flex-col gap-1">
            <span class="text-[0.6rem] uppercase tracking-wider text-base-content/70">Ambiance</span>
            <div class="flex flex-wrap gap-1">
              {% for ambience in game.ambience %}
              {% if ambience == 'chill' %}<span class="badge badge-md gap-1"><i class="ph ph-couch"></i>
                Décontractée</span>
              {% elif ambience == 'comic' %}<span class="badge badge-md gap-1"><i class="ph ph-mask-happy"></i>
                Comique</span>
              {% elif ambience == 'serious' %}<span class="badge badge-md gap-1"><i class="ph ph-book-open-text"></i>
                Sérieuse</span>
              {% elif ambience == 'epic' %}<span class="badge badge-md gap-1"><i class="ph ph-sword"></i>
                Épique</span>
              {% endif %}
              {% endfor %}
            </div>
          </div>
          {% endif %}

        </div>

        {# Row 2: Classification #}
        {% if game.classification %}
        <div class="flex flex-col gap-1.5">
          <span class="text-[0.6rem] uppercase tracking-wider text-base-content/70">Classification</span>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1.5">
            <div class="flex flex-col gap-1.5">
              {% for key, label in [('action', 'Action'), ('interaction', 'Interaction')] %}
              {% if key in game.classification %}
              <div class="flex items-center gap-2">
                <span class="text-base-content/70 w-20 shrink-0">{{ label }}</span>
                <div class="flex gap-0.5 flex-1">
                  <progress class="progress progress-primary flex-1" value="{{ game.classification[key] }}"
                    max="2"></progress>
                </div>
              </div>
              {% endif %}
              {% endfor %}
            </div>
            <div class="flex flex-col gap-1.5">
              {% for key, label in [('investigation', 'Investigation'), ('horror', 'Horreur')] %}
              {% if key in game.classification %}
              <div class="flex items-center gap-2">
                <span class="text-base-content/70 w-20 shrink-0">{{ label }}</span>
                <div class="flex gap-0.5 flex-1">
                  <progress class="progress progress-primary flex-1" value="{{ game.classification[key] }}"
                    max="2"></progress>
                </div>
              </div>
              {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        {% endif %}

      </div>
    </div>

    {# ── SESSIONS + ACTIVITY ── #}
    {% set show_activity = (payload['user_id'] == game.gm.id or payload['is_admin']) and request.path !=
    '/demo/inscription/' %}
    <div class="flex flex-col lg:flex-row gap-4">

      {# Sessions card #}
      <div class="card bg-base-100 shadow-md {% if show_activity %}flex-1 min-w-0{% else %}w-full{% endif %}">
        <div class="card-body p-4">
          <h2 class="card-title text-sm font-bold uppercase tracking-wider text-base-content/70">
            <i class="ph ph-calendar-dots"></i> Sessions
          </h2>
          {% if game.sessions %}
          <div class="max-h-[20rem] overflow-y-auto space-y-2" id="sessions-list">
            {% for session in game.sessions|sort(attribute='start', reverse=true) %}
            <div class="session-row flex items-center gap-3 rounded-lg px-3 py-2.5 border border-base-200"
              data-session-start="{{ session.start }}">
              <div
                class="text-lg font-black text-primary w-8 h-8 flex items-center justify-center rounded-full bg-primary/10 shrink-0">
                {{ loop.revindex }}
              </div>
              <div class="min-w-0">
                <div class="font-semibold leading-tight">{{ session.start|format_datetime('%A %d/%m') }}</div>
                <div class="text-xs text-base-content/70">
                  <i class="ph ph-clock"></i>
                  {{ session.start|format_datetime('%H:%M') }} — {{ session.end|format_datetime('%H:%M') }}
                  <span class="text-base-content/70 ml-1">({{ session.start | duration_hours(session.end) }}h)</span>
                </div>
              </div>
              <div class="ml-auto shrink-0 session-badge"></div>
              <div class="flex items-center gap-1 shrink-0">
                <button class="btn btn-xs btn-square" {% if loop.first %} id="calendarTriggerBtn" {% endif %}
                  onclick="openCalendar(this)" data-name="{{ game.name }} par {{ game.gm.name }} #{{ loop.index }}"
                  data-start-date="{{ session.start|format_datetime('%Y-%m-%d') }}"
                  data-end-date="{{ session.end|format_datetime('%Y-%m-%d') }}"
                  data-start-time="{{ session.start|format_datetime('%H:%M') }}"
                  data-end-time="{{ session.end|format_datetime('%H:%M') }}"
                  data-description="{{ game.type }} - {{ game.gm.name }}" aria-label="Ajouter au calendrier">
                  <i class="ph ph-calendar-plus text-sm"></i>
                </button>
                {% if payload['user_id'] == game.gm.id or payload['is_admin'] %}
                {% if request.path != '/demo/inscription/' %}
                <button class="btn btn-xs btn-square" data-session-id="{{ session.id }}"
                  data-session-index="{{ loop.revindex }}"
                  data-start="{{ session.start|format_datetime('%Y-%m-%dT%H:%M') }}"
                  data-end="{{ session.end|format_datetime('%Y-%m-%dT%H:%M') }}"
                  data-display="{{ session.start|format_datetime }} — {{ session.end|format_datetime }}"
                  onclick="openEditSessionModal(this)" aria-label="Éditer">
                  <i class="ph ph-pencil-simple text-sm"></i>
                </button>
                <button class="btn btn-xs btn-square text-error" data-session-id="{{ session.id }}"
                  data-session-index="{{ loop.revindex }}"
                  data-display="{{ session.start|format_datetime }} — {{ session.end|format_datetime }}"
                  onclick="openDeleteSessionModal(this)" aria-label="Supprimer">
                  <i class="ph ph-trash text-sm"></i>
                </button>
                {% endif %}
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="text-center py-10 text-base-content/30">
            <i class="ph ph-calendar-x text-4xl"></i>
            <p class="mt-2 text-base-content/70">Aucune session planifiée</p>
          </div>
          {% endif %}

          {# Nudge: campaigns in progress where the GM may have forgotten to add the next session #}
          {% if show_activity and game.status not in ['archived', 'draft'] %}
          {% set length_map = {'2 sessions': 2, '3 sessions': 3, '~5 sessions': 5, '~10 sessions': 10} %}
          {% set planned = length_map.get(game.length, 0) %}
          {% set is_open_ended = game.length in ['10+ sessions', '20+ sessions'] %}
          {% set session_count = game.sessions|length %}
          {% if session_count >= 1 and (is_open_ended or (planned > 1 and session_count < planned)) %} <div role="alert"
            class="alert alert-warning text-sm mt-2">
            <i class="ph ph-calendar-plus" aria-hidden="true"></i>
            {% if is_open_ended %}
            <span>Pensez à planifier la prochaine session !</span>
            {% else %}
            <span>{{ session_count }}/{{ planned }} sessions renseignées — pensez à planifier la suite !</span>
            {% endif %}
            <button type="button" class="btn btn-sm btn-warning gap-1" onclick="openAddSessionModal()">
              <i class="ph ph-plus" aria-hidden="true"></i> Ajouter
            </button>
        </div>
        {% endif %}
        {% endif %}
      </div>
    </div>

    {# Activity card (GM/Admin only) #}
    {% if show_activity %}
    <div class="card bg-base-100 shadow-md flex-1 min-w-0">
      <div class="card-body p-4" id="event-list">
        <h2 class="card-title text-sm font-bold uppercase tracking-wider text-base-content/70">
          <i class="ph ph-notebook"></i> Activité
        </h2>
        {% if game.events %}
        <div class="max-h-[20rem] overflow-y-auto">
          <ul class="timeline timeline-vertical timeline-compact">
            {% for event in game.events|sort(attribute='timestamp')|reverse %}
            <li>
              {% if not loop.first %}
              <hr />{% endif %}
              <div class="timeline-start text-xs text-base-content/70 whitespace-nowrap">
                {{ event.timestamp|format_datetime('%d/%m %H:%M') }}
              </div>
              <div class="timeline-middle">
                {% if event.action == 'create' %}
                <i class="ph ph-plus-circle text-success"></i>
                {% elif event.action == 'edit' %}
                <i class="ph ph-pencil-simple text-info"></i>
                {% elif event.action == 'delete' %}
                <i class="ph ph-trash text-error"></i>
                {% elif event.action == 'create-session' %}
                <i class="ph ph-calendar-plus text-success"></i>
                {% elif event.action == 'edit-session' %}
                <i class="ph ph-calendar-check text-info"></i>
                {% elif event.action == 'delete-session' %}
                <i class="ph ph-calendar-x text-error"></i>
                {% elif event.action == 'register' %}
                <i class="ph ph-user-plus text-success"></i>
                {% elif event.action == 'unregister' %}
                <i class="ph ph-user-minus text-error/40"></i>
                {% elif event.action == 'alert' %}
                <i class="ph ph-bell-ringing text-warning"></i>
                {% else %}
                <i class="ph ph-dot-outline text-base-content/30"></i>
                {% endif %}
              </div>
              <div class="timeline-end timeline-box border-base-200 py-2 px-3">
                <div class="font-semibold text-sm">
                  {% if event.action == 'create' %}Création
                  {% elif event.action == 'edit' %}Édition
                  {% elif event.action == 'delete' %}Suppression
                  {% elif event.action == 'create-session' %}Session ajoutée
                  {% elif event.action == 'edit-session' %}Session modifiée
                  {% elif event.action == 'delete-session' %}Session supprimée
                  {% elif event.action == 'register' %}Inscription
                  {% elif event.action == 'unregister' %}Désinscription
                  {% elif event.action == 'alert' %}Alerte
                  {% else %}{{ event.action }}
                  {% endif %}
                </div>
                {% if event.description %}
                <p class="text-xs text-base-content/70 mt-0.5">{{ event.description }}</p>
                {% endif %}
                {% if event.user %}
                <p class="text-xs text-base-content/70 mt-0.5">
                  {% if event.action in ('register', 'unregister') %}joueur·euse :{% else %}par{% endif %}
                  {{ event.user.name }}</p>
                {% endif %}
              </div>
              {% if not loop.last %}
              <hr />{% endif %}
            </li>
            {% endfor %}
          </ul>
        </div>
        {% else %}
        <div class="text-center py-10 text-base-content/30">
          <i class="ph ph-notebook text-4xl"></i>
          <p class="mt-2 text-base-content/70">Aucune activité enregistrée</p>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

  </div>

</div>

{# ── RIGHT COLUMN ── #}
<div class="w-full lg:w-72 xl:w-80 flex-shrink-0 space-y-4">

  {# ── PLAYER ROSTER ── #}
  <div id="playerListCard" class="card bg-base-100 shadow-md overflow-hidden">
    <div class="card-body p-0">
      {# Count header #}
      <div class="bg-base-200 rounded-t-2xl p-4 text-center">
        <div class="text-3xl font-black text-primary">
          {{ game.players|length }}<span class="text-base-content/20">/</span>{{ game.party_size }}
        </div>
        <div class="text-sm font-semibold text-base-content/70">
          Joueur·euses
          {% if game.party_selection and game.status != "closed" %}
          · <span class="text-sm">sur sélection</span>
          {% endif %}
        </div>
      </div>

      {# Avatars — grid of 4 columns; no rows of 3 #}
      <div class="p-4">
        {% set player_count = game.players|length %}
        {% if game.party_selection %}
        {% if game.status == "open" %}{% set total_slots = player_count + 1 if player_count >= game.party_size else
        game.party_size %}
        {% else %}{% set total_slots = [player_count, game.party_size]|max %}{% endif %}
        {% else %}{% set total_slots = game.party_size %}{% endif %}
        {% set empty_slots = total_slots - player_count %}
        <div class="grid grid-cols-4 gap-2">
          {% for player in game.players %}
          <div class="player-avatar-wrapper flex flex-col items-center">
            <div class="tooltip" data-tip="{{ player.name }}">
              <div class="avatar">
                <div class="w-10 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                  <img src="{{ player.avatar }}" alt="{{ player.name }}" />
                </div>
              </div>
            </div>
            <div class="text-[0.6rem] mt-0.5 truncate w-full text-center leading-tight">{{ player.name }}</div>
          </div>
          {% endfor %}
          {% for _ in range(empty_slots) %}
          <div class="flex flex-col items-center opacity-30">
            <div class="avatar placeholder">
              <div class="bg-base-300 text-base-content w-10 rounded-full flex items-center justify-center">
                <i class="ph ph-user text-lg"></i>
              </div>
            </div>
            <div class="text-[0.6rem] mt-0.5 leading-tight">Libre</div>
          </div>
          {% endfor %}
        </div>

        {% if player_count > game.party_size and (payload['user_id'] == game.gm.id or payload['is_admin']) %}
        <div role="alert" class="alert alert-warning mt-3 py-2 text-sm">
          <i class="ph ph-warning"></i>
          <span>{{ player_count - game.party_size }} joueur·euse{{ 's' if player_count - game.party_size > 1 }} en
            trop</span>
        </div>
        {% endif %}
      </div>

      {# Footer info #}
      <div class="bg-base-200 rounded-b-2xl px-4 py-3 text-center text-xs text-base-content/70 space-y-0.5">
        <div>
          {% if game.xp == "beginners" %}Réservé aux débutants
          {% elif game.xp == "seasoned" %}Interdit aux débutants
          {% else %}Débutants bienvenus{% endif %}
        </div>
        <div>
          Personnages
          {% if game.characters == "self" %}à faire seul·e
          {% elif game.characters == "with_gm" %}à faire avec le·a MJ
          {% elif game.characters == "pregen" %}prétirés
          {% else %}à faire seul·e ou avec le·a MJ{% endif %}
        </div>
      </div>
    </div>
  </div>

  {# ── ACTIONS ── #}
  <div class="space-y-2 sticky top-20">
    {# Sign up button #}
    {% if request.path == '/demo/inscription/' or (payload['user_id'] != game.gm.id and game.status == "open") %}
    {% if not is_player %}
    <form method="post" action="/annonces/{{ game.slug }}/inscription/">
      <input type="hidden" name="csrf_token" value="{{ csrf_token() }}">
      <div class="tooltip w-full"
        data-tip="{% if not payload.get('user_id') %}Connectez-vous pour vous inscrire{% else %}S'inscrire à la partie{% endif %}">
        <button type="submit" id="signup-btn" class="btn btn-success btn-block gap-2" {% if not payload.get('user_id')
          or (payload['user_id']==game.gm.id) %}disabled{% endif %}>
