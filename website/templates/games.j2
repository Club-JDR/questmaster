{% extends 'base.j2' %}
{% block title %}{{ title }}{% endblock %}
{% block content %}

<h1 class="text-center font-black text-2xl my-4">
  <i class="ph ph-megaphone"></i> {{ title }}
</h1>

{% if request.path == '/mes_parties/' %}
<div role="alert" class="alert alert-info mb-3">
  <i class="ph ph-info"></i>
  <span>Les parties pour lesquelles je suis joueur·euse.</span>
</div>
{% elif request.path == '/mes_annonces/' %}
<div role="alert" class="alert alert-info mb-3">
  <i class="ph ph-info"></i>
  <span>Les parties pour lesquelles je suis MJ.</span>
</div>
{% endif %}

{% include 'searchbar.j2' %}

{% if games|length == 0 %}
<div role="alert" class="alert alert-warning mt-4">
  <i class="ph ph-warning"></i>
  <span>Aucune annonce correspondant aux filtres sélectionnés !</span>
</div>
{% else %}
<div id="game-cards-container" class="flex overflow-x-auto snap-x snap-mandatory gap-3 mt-4 pb-3 scrollbar-hide sm:grid sm:grid-cols-2 sm:gap-4 sm:overflow-visible sm:pb-0 lg:grid-cols-3 xl:grid-cols-4">
  {% if request.path == '/annonces/' %}
    {% for i in range(games|length) %}{% include "game_card_skeleton.j2" %}{% endfor %}
  {% else %}
    {% include "game_cards_container.j2" %}
  {% endif %}
</div>
<div id="carousel-indicator" class="flex justify-center gap-1.5 mt-2 sm:hidden" aria-hidden="true"></div>
{% endif %}

{# Pagination — sticky bottom bar #}
{% if prev_url or next_url %}
<div class="fixed bottom-0 left-0 right-0 z-40 flex justify-center py-3 bg-base-200/80 backdrop-blur-sm border-t border-base-300">
  <div class="join">
    <a class="join-item btn btn-sm {% if not prev_url %}btn-disabled{% endif %}" href="{{ prev_url or '#' }}">
      <i class="ph ph-caret-left"></i> Précédentes
    </a>
    <a class="join-item btn btn-sm {% if not next_url %}btn-disabled{% endif %}" href="{{ next_url or '#' }}">
      Suivantes <i class="ph ph-caret-right"></i>
    </a>
  </div>
</div>
{% endif %}

{% endblock %}

{% block scripts %}{{ super() }}
<script src="/static/js/cards.js"></script>
{% endblock %}
