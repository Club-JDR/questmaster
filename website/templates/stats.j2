{% extends 'base.j2' %}
{% block title %}Statistiques mensuelles{% endblock %}
{% block content %}

<h1 class="text-center font-black text-2xl my-4">
  <i class="ph ph-chart-line"></i> Statistiques — {{ month }}/{{ year }}
</h1>

<div class="flex justify-between mb-6">
  <a class="btn btn-primary btn-sm gap-1" href="{{ url_for('stats.get_stats', year=prev_year, month=prev_month) }}">
    <i class="ph ph-caret-left"></i> Mois précédent
  </a>
  <a class="btn btn-primary btn-sm gap-1" href="{{ url_for('stats.get_stats', year=next_year, month=next_month) }}">
    Mois suivant <i class="ph ph-caret-right"></i>
  </a>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="card bg-base-100 shadow-md text-center">
    <div class="card-body">
      <h2 class="card-title justify-center text-success"><i class="ph ph-scroll"></i> Sessions OS</h2>
      <p class="text-5xl font-black text-success">{{ num_os }}</p>
    </div>
  </div>
  <div class="card bg-base-100 shadow-md text-center">
    <div class="card-body">
      <h2 class="card-title justify-center text-primary"><i class="ph ph-books"></i> Sessions de Campagnes</h2>
      <p class="text-5xl font-black text-primary">{{ num_campaign }}</p>
    </div>
  </div>
  <div class="card bg-base-100 shadow-md text-center">
    <div class="card-body">
      <h2 class="card-title justify-center"><i class="ph ph-chart-bar"></i> Total</h2>
      <p class="text-5xl font-black">{{ num_os + num_campaign }}</p>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">

  <div class="card bg-base-100 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-success"><i class="ph ph-scroll"></i> Liste des OS</h2>
      {% for system, games in os.items() %}
      <div class="mt-3">
        <h3 class="font-semibold text-success text-sm mb-1">{{ system }}
          <span class="text-base-content/40 font-normal">({{ games|length }} scénario{% if games|length > 1 %}s{% endif %})</span>
        </h3>
        <div class="overflow-x-auto">
          <table class="table table-sm table-zebra w-full">
            <thead>
              <tr><th>#</th><th>Nom de la session</th><th>MJ</th><th>Sessions</th></tr>
            </thead>
            <tbody>
              {% for slug, info in os[system].items() | sort(attribute='1.count', reverse=true) %}
              <tr>
                <td>{{ loop.index }}</td>
                <td>{{ info.name }}</td>
                <td>{{ info.gm }}</td>
                <td>{{ info.count }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

  <div class="card bg-base-100 shadow-md">
    <div class="card-body">
      <h2 class="card-title text-primary"><i class="ph ph-books"></i> Liste des campagnes</h2>
      {% for system, games in campaign.items() %}
      <div class="mt-3">
        <h3 class="font-semibold text-primary text-sm mb-1">{{ system }}
          <span class="text-base-content/40 font-normal">({{ games|length }} campagne{% if games|length > 1 %}s{% endif %})</span>
        </h3>
        <div class="overflow-x-auto">
          <table class="table table-sm table-zebra w-full">
            <thead>
              <tr><th>#</th><th>Nom de la session</th><th>MJ</th><th>Sessions</th></tr>
            </thead>
            <tbody>
              {% for slug, info in campaign[system].items() | sort(attribute='1.count', reverse=true) %}
              <tr>
                <td>{{ loop.index }}</td>
                <td>{{ info.name }}</td>
                <td>{{ info.gm }}</td>
                <td>{{ info.count }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>

</div>

<div class="card bg-base-100 shadow-md">
  <div class="card-body">
    <h2 class="card-title justify-center"><i class="ph ph-trophy"></i> Classement des MJs</h2>
    <div class="overflow-x-auto">
      <table class="table table-zebra text-center">
        <thead>
          <tr><th>#</th><th>MJ</th><th>Sessions</th></tr>
        </thead>
        <tbody>
          {% for mj, count in mjs %}
          <tr>
            <td>
              {% if loop.index == 1 %}🥇
              {% elif loop.index == 2 %}🥈
              {% elif loop.index == 3 %}🥉
              {% else %}{{ loop.index }}{% endif %}
            </td>
            <td>{{ mj }}</td>
            <td>{{ count }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

{% endblock %}
