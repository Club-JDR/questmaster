{% extends 'base.j2' %}
{% block title %}Badges{% endblock %}
{% block content %}

<h1 class="text-center font-black text-2xl my-4">
  <i class="ph ph-trophy"></i> Badges de {{ user.name }}
</h1>

<form method="GET" action="{{ url_for('misc.list_user_badges') }}" class="mb-6">
  <div data-user-typeahead class="max-w-md mx-auto">
    <div class="flex gap-2 items-start">
      <div class="relative flex-1">
        <label for="badgeUserSearch" class="sr-only">Rechercher un·e utilisateur·rice</label>
        <input type="text" id="badgeUserSearch" class="input input-bordered w-full"
          placeholder="Nom d'utilisateur·rice ou ID Discord"
          role="combobox" aria-expanded="false" aria-autocomplete="list"
          aria-controls="badgeUserSearchList" autocomplete="off">
        <ul id="badgeUserSearchList" role="listbox" aria-label="Suggestions"
          class="menu menu-sm bg-base-100 rounded-box shadow-lg border border-base-300 absolute z-10 mt-1 w-full max-h-60 overflow-y-auto flex-nowrap hidden"></ul>
      </div>
      <button class="btn btn-primary" type="submit">Rechercher</button>
    </div>
    <input type="hidden" name="user_id">
    <p class="text-error text-xs mt-2 hidden" data-typeahead-error role="alert"></p>
  </div>
</form>

{% if user_id %}
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
  {% for t in trophies|sort(attribute='name') %}
  <div class="card bg-base-100 shadow-md">
    <div class="card-body items-center text-center py-4 px-3">
      <img src="{{ t.icon }}" class="w-16 h-16 object-contain" alt="{{ t.name }}">
      <h3 class="font-semibold text-sm mt-2">{{ t.name }}</h3>
      <span class="badge badge-ghost badge-sm">×{{ t.quantity }}</span>
    </div>
  </div>
  {% endfor %}
</div>
{% else %}
<div role="alert" class="alert alert-warning max-w-md mx-auto">
  <i class="ph ph-warning"></i>
  <span>Aucun utilisateur trouvé. Veuillez entrer un ID valide.</span>
</div>
{% endif %}

{% endblock %}

{% block scripts %}
{{ super() }}
<script src="/static/js/user-typeahead.js" defer></script>
{% endblock %}