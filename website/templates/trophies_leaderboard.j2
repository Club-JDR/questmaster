{% extends 'base.j2' %}
{% block title %}Classement des badges{% endblock %}
{% block content %}

<h1 class="text-center font-black text-2xl my-4">
  <i class="ph ph-trophy"></i> Classement des badges
</h1>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">

  <div class="space-y-6">

    <div class="card bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title justify-center text-success"><i class="ph ph-medal" aria-hidden="true"></i> Top 10 joueurs — OS</h2>
        <div class="overflow-x-auto">
          <table class="table table-sm table-zebra">
            <thead>
              <tr><th>#</th><th>Nom</th><th>Badges</th></tr>
            </thead>
            <tbody>
              {% set ns = namespace(rank=1) %}
              {% for player, total in os_leaderboard %}
              <tr>
                <td>{{ ns.rank }}</td><td>{{ player.name }}</td><td>{{ total }}</td>
              </tr>
              {% set ns.rank = ns.rank + 1 %}
              {% endfor %}
              {% for i in range(10 - os_leaderboard|length) %}
              <tr class="opacity-30">
                <td>{{ ns.rank }}</td><td>—</td><td>—</td>
              </tr>
              {% set ns.rank = ns.rank + 1 %}
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow-md">
      <div class="card-body">
        <h2 class="card-title justify-center text-primary"><i class="ph ph-medal" aria-hidden="true"></i> Top 10 joueurs — Campagnes</h2>
